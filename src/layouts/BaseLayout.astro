---
import "../theme/index.scss";
import layoutStyles from "../theme/layout.module.scss";
import Header from "../components/PageHeader.astro";
import { ClientRouter } from "astro:transitions";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getSeoData } from "../lib/seo";
import "typeface-montserrat";
import "typeface-noto-sans";

const props = Astro.props;
const image = props?.image ?? props?.entry?.data?.image;
const site = Astro.site ?? new URL(Astro.url.origin);

const seo = await getSeoData({
  title: props?.title ?? props?.entry?.data?.title,
  description: props?.description ?? props?.entry?.data?.description,
  siteTitle: SITE_TITLE,
  siteDescription: SITE_DESCRIPTION,
  image,
  currentUrl: Astro.url,
  site,
  isArticle: Boolean(props?.entry),
  publishedTime: props?.entry?.data?.pubDate,
  author: props?.entry?.data?.author,
  tags: props?.entry?.data?.tags,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={seo.canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={seo.description} />
    <title>{seo.fullTitle}</title>

    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:type" content={seo.isArticle ? "article" : "website"} />
    <meta property="og:url" content={seo.canonicalUrl} />
    <meta property="og:title" content={seo.fullTitle} />
    <meta property="og:description" content={seo.description} />
    {seo.ogImage && <meta property="og:image" content={seo.ogImage} />}
    {seo.imageAlt && <meta property="og:image:alt" content={seo.imageAlt} />}
    {
      seo.imageWidth && (
        <meta property="og:image:width" content={String(seo.imageWidth)} />
      )
    }
    {
      seo.imageHeight && (
        <meta property="og:image:height" content={String(seo.imageHeight)} />
      )
    }
    {
      seo.publishedTime && (
        <meta property="article:published_time" content={seo.publishedTime} />
      )
    }
    {seo.author && <meta property="article:author" content={seo.author} />}
    {seo.tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content={seo.twitterCard} />
    <meta name="twitter:title" content={seo.fullTitle} />
    <meta name="twitter:description" content={seo.description} />
    {seo.ogImage && <meta name="twitter:image" content={seo.ogImage} />}
    {seo.imageAlt && <meta name="twitter:image:alt" content={seo.imageAlt} />}

    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header image={props?.entry?.data?.image} slug={props?.entry?.slug} />
    <main class={`pageMain ${layoutStyles.row}`} id="main-content">
      <slot {...props} />
    </main>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -100%);
    display: inline-block;
    padding: 0.5rem 1rem;
    z-index: var(--z-modal);
    background: var(--c-white);
    transition: transform 0.2s ease-in-out;
  }

  .skip-link:focus-visible {
    transform: translate(-50%, 100%);
  }

  code {
    grid-column: full;
  }

  .pageMain {
    padding-block: var(--s-4) var(--s-8);
  }

  .pageMain > * {
    max-width: var(--s-readable-text-width);
  }

  .pageMain img {
    max-width: 100%;
    height: auto;
  }

  .astro-code {
    grid-column: full;
    display: grid;
    grid-template-columns:
      [full-start] minmax(var(--s-5), 1fr)
      [content-start] minmax(0, var(--s-max-content-width))
      [content-end] minmax(var(--s-5), 1fr) [full-end];
    grid-auto-rows: min-content;
    max-width: unset;
  }

  .astro-code [style="color:#6A737D"] {
    color: hsl(0, 0%, 70%) !important;
  }

  .pageMain > pre > * {
    grid-column: content;
  }
</style>
