---
import styles from "./PageHeader.module.scss";
import { Image } from "astro:assets";

const { image } = Astro.props;
---

<header class={styles.stickyBar}>
  <a href="/" class={styles.stickyLogo} aria-label="Zero Context – home">
    <span class={styles.logoFull}>Zero Context</span>
    <span class={styles.logoShort} aria-hidden="true">O</span>
  </a>
  <nav class={styles.stickyNav} aria-label="Site navigation">
    <a href="/about" class={styles.navLink}>About</a>
    <a href="/rss.xml" class={styles.navLink} aria-label="RSS feed">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"
        ></path>
      </svg>
    </a>
  </nav>
</header>

{
  image && (
    <div class={styles.hero}>
      <div class={styles.backgroundImage}>
        <Image
          {...image}
          class={styles.picture}
          widths={[1700, 1200, 992, 768, 650, 375]}
          aria-hidden="true"
        />
      </div>
      <div class={styles.scrollOverlay} />
    </div>
  )
}
