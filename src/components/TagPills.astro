---
interface Props {
  tags: string[];
  mode?: "link" | "button";
  ariaLabel?: string;
  basePath?: string;
  queryParamName?: string;
  activeTag?: string | null;
}

const {
  tags,
  mode = "link",
  ariaLabel = "Tags",
  basePath = "/",
  queryParamName = "tag",
  activeTag = null,
} = Astro.props;

const buildTagHref = (tag: string) => {
  const params = new URLSearchParams([[queryParamName, tag]]);
  return `${basePath}?${params.toString()}`;
};
---

<div
  class={`tagList ${mode === "button" ? "isFilter" : "isLinks"}`}
  aria-label={ariaLabel}
  role={mode === "button" ? "group" : undefined}
>
  {
    tags.map((tag) =>
      mode === "button" ? (
        <button
          type="button"
          class="tagPill"
          data-tag={tag}
          aria-pressed={tag === activeTag ? "true" : "false"}
        >
          {tag}
        </button>
      ) : (
        <a href={buildTagHref(tag)} class="tagPill">
          {tag}
        </a>
      ),
    )
  }
</div>

<style>
  .tagList {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-1);
  }

  .tagPill {
    display: inline-block;
    padding: var(--tag-padding-block, calc(var(--s-1) / 2))
      var(--tag-padding-inline, var(--s-2));
    font-family: var(--font-family);
    font-size: var(--tag-font-size, var(--t-body-xs));
    font-weight: var(--tag-font-weight, var(--fw-medium));
    border: 1px solid var(--c-brand-primary);
    border-radius: 100px;
    background-color: transparent;
    color: var(--c-brand-secondary);
    text-decoration: none;
    cursor: pointer;
    transition:
      background-color var(--ease-duration-s) var(--ease-1),
      color var(--ease-duration-s) var(--ease-1);

    &:hover {
      background-color: var(--c-brand-primary-25);
    }

    &:focus-visible {
      outline: 2px solid var(--c-focus);
      outline-offset: 2px;
    }
  }

  .isLinks {
    margin-block-start: var(--s-2);
  }

  .isFilter {
    display: none;

    .tagPill {
      --tag-padding-block: var(--s-1);
      --tag-font-size: var(--t-body-s);
      --tag-font-weight: var(--fw-regular);
    }

    .tagPill[aria-pressed="true"] {
      background-color: var(--c-brand-primary);
      color: var(--c-white);
      font-weight: var(--fw-medium);

      &::after {
        content: " x";
        font-weight: var(--fw-bold);
      }
    }
  }

  @media (min-width: 650px) {
    .isFilter {
      display: flex;
    }
  }
</style>
