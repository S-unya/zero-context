---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found">
    <header class="page-header">
        <h1>404 — lost in the blitherings</h1>
    </header>
    <p>
        That page doesn't exist. It may have moved, or perhaps it never did.
    </p>
    <p>
        <a href="/">Back to the musings →</a>
    </p>
</Layout>

<style>
    .page-header {
        padding-block-start: var(--s-2);
    }
</style>
