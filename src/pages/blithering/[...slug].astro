---
import { getCollection } from "astro:content";
import BlitheringFooter from "../../components/BlitheringFooter.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const blogEntries = await getCollection("blithering");
    return blogEntries.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await entry.render();
const { title, pubDate, author = "Śūnya", tags = [] } = entry.data;
const readingTime = remarkPluginFrontmatter?.readingTime;

const localeDateOptions = {
    weekday: "long",
    year: "numeric",
    month: "long",
    day: "numeric",
} as const;
---

<BaseLayout {...Astro.props}>
    <header class="blog-header">
        <h1>{title}</h1>
        <dl>
            <dt>Date:</dt>
            <dd>
                <time datetime={new Date(pubDate).toString()}
                    >{
                        new Date(pubDate).toLocaleDateString(
                            undefined,
                            localeDateOptions,
                        )
                    }</time
                >
            </dd>
            <dt>Author:</dt>
            <dd>{author}</dd>
            {
                readingTime && (
                    <>
                        <dt>Reading time:</dt>
                        <dd>{readingTime}</dd>
                    </>
                )
            }
        </dl>
        {
            tags.length > 0 && (
                <div class="tagList" aria-label="Post tags">
                    {tags.map((tag: string) => (
                        <a
                            href={`/?tag=${encodeURIComponent(tag)}`}
                            class="tag"
                        >
                            {tag}
                        </a>
                    ))}
                </div>
            )
        }
    </header>
    <Content />
    <BlitheringFooter currentArticleFile={entry.id} />
</BaseLayout>

<style>
    .blog-header {
        --s-readable-text-width: 100%;
    }

    dl {
        display: flex;
        flex-flow: row wrap;
        gap: var(--s-1);
        color: var(--c-gray-600);
        font-size: var(--t-body-s);
        border-bottom: 1px solid var(--c-gray-200);
        padding-block-end: var(--s-1);
    }

    dd {
        padding-inline-end: var(--s-1);
        border-right: 1px solid var(--c-gray-200);
    }

    dd:last-child {
        padding-inline-end: 0;
        border-right: 0 none;
    }

    .tagList {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-1);
        margin-block-start: var(--s-2);
    }

    .tag {
        display: inline-block;
        padding: calc(var(--s-1) / 2) var(--s-2);
        font-size: var(--t-body-xs);
        font-weight: var(--fw-medium);
        border: 1px solid var(--c-brand-primary);
        border-radius: 100px;
        color: var(--c-brand-primary);
        text-decoration: none;
        transition:
            background-color var(--ease-duration-s) var(--ease-1),
            color var(--ease-duration-s) var(--ease-1);

        &:hover {
            background-color: var(--c-brand-primary-25);
        }

        &:focus-visible {
            outline: 2px solid var(--c-focus);
            outline-offset: 2px;
        }
    }
</style>
